programa {
  funcao inicio() {
  real valor_total,porcentagem,valor_parte 

  escreva ("digite vfalor total: ")
  leia (valor_total)

  escreva ("digite o valor da porcentagem: ")
  leia (porcentagem)

  valor_parte = valor_total * ( porcentagem / 100 ) 

  escreva ("o valor_parte é (valor_total * ( porcentagem / 100 ) ) é:" , valor_parte )

  }
}
